#!/usr/bin/env node
'use strict';

/**
 * gid — set the current git repository's user.name and user.email to the
 * values configured in the `.env` file living next to this script.
 *
 * Config: a `.env` file next to this script with:
 *   GIT_USER_NAME=Your Name
 *   GIT_USER_EMAIL=you@example.com
 *
 * Sets them locally (per-repo, no --global), so different repos can use
 * different identities.
 */

const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');

const SCRIPT_DIR = path.dirname(fs.realpathSync(process.argv[1]));

// --- tiny ANSI helpers (auto-disabled when not a TTY) ---
const useColor = process.stdout.isTTY;
const c = (code, s) => (useColor ? `\x1b[${code}m${s}\x1b[0m` : s);
const bold = (s) => c('1', s);
const dim = (s) => c('2', s);
const red = (s) => c('31', s);
const green = (s) => c('32', s);
const cyan = (s) => c('36', s);

function die(msg) {
  console.error(`${red('✗')} ${msg}`);
  process.exit(1);
}

function git(args, opts = {}) {
  return execFileSync('git', args, { encoding: 'utf8', ...opts });
}

function loadEnv() {
  const file = path.join(SCRIPT_DIR, '.env');
  const env = {};
  if (fs.existsSync(file)) {
    for (const raw of fs.readFileSync(file, 'utf8').split('\n')) {
      const line = raw.trim();
      if (!line || line.startsWith('#')) continue;
      const eq = line.indexOf('=');
      if (eq === -1) continue;
      const key = line.slice(0, eq).trim();
      let val = line.slice(eq + 1).trim();
      if (
        (val.startsWith('"') && val.endsWith('"')) ||
        (val.startsWith("'") && val.endsWith("'"))
      ) {
        val = val.slice(1, -1);
      }
      env[key] = val;
    }
  }
  // real environment variables take precedence over the .env file
  return { ...env, ...process.env };
}

function ensureGitRepo() {
  try {
    git(['rev-parse', '--is-inside-work-tree'], { stdio: ['ignore', 'pipe', 'ignore'] });
  } catch {
    die('Not inside a git repository.');
  }
}

function currentLocal(key) {
  try {
    return git(['config', '--local', key], { stdio: ['ignore', 'pipe', 'ignore'] }).trim();
  } catch {
    return '';
  }
}

function applyField(key, next) {
  const before = currentLocal(key);
  git(['config', '--local', key, next]);
  const label = key.padEnd(10);
  if (before && before !== next) {
    console.log(`  ${bold(label)} ${dim(before)} ${dim('→')} ${green(next)}`);
  } else {
    console.log(`  ${bold(label)} ${green(next)}`);
  }
}

function main() {
  ensureGitRepo();

  const env = loadEnv();
  const name = (env.GIT_USER_NAME || '').trim();
  const email = (env.GIT_USER_EMAIL || '').trim();

  if (!name && !email) {
    die('Neither GIT_USER_NAME nor GIT_USER_EMAIL is set in .env.');
  }

  console.log(`${cyan('Setting local git identity for this repository:')}`);
  if (name) applyField('user.name', name);
  if (email) applyField('user.email', email);

  console.log(`${green('✓')} Done.`);
}

main();
